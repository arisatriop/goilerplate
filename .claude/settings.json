{
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go mod tidy:*)",
      "Bash(golangci-lint run:*)",
      "Bash(make run:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(make migrate-up:*)",
      "Bash(make migrate-down:*)",
      "Bash(make migrate-status:*)",
      "Bash(make migrate-create:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(curl *)",
      "Bash(grep -E:*)",
      "Bash(grep *)",
      "Bash(date:*)",
      "Bash(python3:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(rm -f /tmp/gh_*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(.claude/scripts/jira-tickets.sh:*)",
      "Bash(.claude/scripts/jira-ticket.sh:*)",
      "Bash(.claude/scripts/jira-transition.sh:*)",
      "Bash(.claude/scripts/jira-comment.sh:*)",
      "Bash(.claude/scripts/gh-login.sh:*)",
      "mcp__jira__*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(DROP TABLE:*)",
      "Bash(DROP DATABASE:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "postgres",
    "github",
    "jira"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && go vet ./... 2>&1 | tail -20 || true"
          }
        ]
      }
    ]
  }
}
